# Пример переменных окружения. Скопируйте в .env и заполните своими значениями.
# .env НИКОГДА не коммитить в репозиторий!

# Ключи API MEXC (создать в личном кабинете, с IP-белым списком)
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here

# Параметры отбора (необязательные — есть значения по умолчанию)
ARB_TOP_N=30
ARB_TAKER_FEE=0.0

# Риск и исполнение (веха 6, необязательные — есть значения по умолчанию)
ARB_SLIPPAGE_PCT=0.05        # запас цены для FOK, %
ARB_RISK_MAX_AMOUNT=1000.0   # максимум на одну связку, USDT
ARB_RISK_COOLDOWN=5.0        # пауза между сделками, сек
ARB_RISK_MAX_TRADES=50       # дневной лимит числа сделок
ARB_RISK_DAILY_LOSS=50.0     # дневной лимит потерь, USDT
ARB_RESCAN_INTERVAL=3.0      # период пересмотра топа по спреду, сек

# Telegram (веха 5)
TELEGRAM_BOT_TOKEN=8606472734:AAFOd9OYebySmdGKdq_jh82oSaGbkmaJV30
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Sheets (веха 4): путь к JSON сервисного аккаунта и ID таблицы
GOOGLE_SA_JSON=./service_account.json
GOOGLE_SHEET_ID=1EBo8kY4DFVU7lCUn3D_USGX32KyPZbMa2v7JCu0osbg
