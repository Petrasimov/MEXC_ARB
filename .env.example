# Пример переменных окружения. Скопируйте в .env и заполните своими значениями.
# .env НИКОГДА не коммитить в репозиторий!

# Ключи API MEXC (создать в личном кабинете, с IP-белым списком)
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here

# Параметры отбора (необязательные — есть значения по умолчанию)
ARB_TOP_N=30
ARB_TAKER_FEE=0.0

# Telegram (веха 5)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Sheets (веха 4): путь к JSON сервисного аккаунта и ID таблицы
GOOGLE_SA_JSON=./service_account.json
GOOGLE_SHEET_ID=your_sheet_id_here
